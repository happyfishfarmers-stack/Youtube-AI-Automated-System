# =============================================================================
# ThumbnailFlow AI — Environment Variables
# Copy to .env.local (web) and .env (api/services)
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/thumbnailflow?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/thumbnailflow?schema=public"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- App URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# --- JWT / API Security ---
JWT_SECRET="generate-a-64-char-random-secret"
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=60000

# --- AI Providers ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- YouTube / Trends ---
YOUTUBE_API_KEY=""
GOOGLE_TRENDS_API_KEY=""

# --- Design APIs ---
CANVA_API_KEY=""
ADOBE_EXPRESS_CLIENT_ID=""
ADOBE_EXPRESS_CLIENT_SECRET=""

# --- Social / Automation ---
MAKE_WEBHOOK_URL=""
ZAPIER_WEBHOOK_URL=""

# --- Email (Lead outreach) ---
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# --- Redis (queues — Phase 5) ---
REDIS_URL="redis://localhost:6379"
